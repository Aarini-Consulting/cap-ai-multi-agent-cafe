{
  "name": "cafe-multi-agent",
  "version": "1.0.0",
  "description": "Café with Multi-Agent Orchestrator — Kitchen Manager + Grievance Manager specialists",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch --profile hybrid",
    "ui:build": "cd app/chat-ui-src && npx vite build",
    "ui:dev": "cd app/chat-ui-src && npx vite",
    "dev": "npm run ui:build && npm run watch",
    "test": "npx jest --silent"
  },
  "dependencies": {
    "@sap/cds": "^9",
    "@cap-js/audit-logging": "^1",
    "@cap-js/hana": "^2",
    "@sap/xssec": "^4",
    "passport": "^0.7",
    "@sap-ai-sdk/langchain": "^2.11.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/core": "^1.2.0",
    "langchain": "^1.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "cds": {
    "requires": {
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "cafe-user": {
              "password": "initial",
              "roles": ["authenticated-user"]
            }
          }
        }
      },
      "[production]": {
        "db": "hana",
        "auth": "xsuaa"
      }
    }
  }
}
