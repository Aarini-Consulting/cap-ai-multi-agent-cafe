{
  "name": "cap-ai-multi-agent-cafe",
  "version": "1.0.0",
  "description": "AI-Ready CAP Multi-Agent Cafe Workshop",
  "scripts": { "start": "cds-serve" },
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "passport": "^0.7"
  },
